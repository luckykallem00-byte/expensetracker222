# Backend environment variables for Firebase Admin
PORT=4000
# FRONTEND_URL accepts a single origin or comma-separated origins (e.g. https://myapp.vercel.app)
FRONTEND_URL=http://localhost:5173
FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com
# Either paste the full JSON service account object here, or paste a base64-encoded JSON string.
FIREBASE_SERVICE_ACCOUNT_KEY=
